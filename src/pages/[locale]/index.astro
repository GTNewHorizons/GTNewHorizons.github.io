---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import Logo from "../../assets/logo.svg";
import FeatureTabs from "../../components/home/FeatureTabs.astro";
import Carousel from "../../components/home/Carousel.astro";
import CallToAction from "../../components/home/CallToAction.astro";
import AgesWalkthrough from "../../components/home/AgesWalkthrough.astro";
import { useTranslations, locales, localizePath } from "../../i18n";
import type { Locale } from "../../i18n";

export async function getStaticPaths() {
  return locales.map(locale => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };
const t = useTranslations(locale);
---

<BaseLayout locale={locale} title={t("home.welcome")}>
  <div class="bg-custom-dark text-white">
    <!-- Hero Section -->
    <section class="container mx-auto px-6 md:px-12 lg:px-16 pt-3 md:pt-6 lg:pt-12">
      <div class="flex flex-col lg:flex-row items-center justify-center lg:justify-between gap-3 md:gap-4 lg:gap-9">
        <!-- Left Content -->
        <div class="lg:flex-1 text-center lg:text-left order-2 lg:order-1">
          <h1 class="text-xl sm:text-3xl lg:text-4xl font-bold mb-1.5">{t("home.welcome")}</h1>
          <h2 class="font-audiowide text-xl sm:text-2xl lg:text-4xl text-custom-blue mb-4">{t("common.brand.full")}</h2>
          <p class="text-lg sm:text-xl text-gray-300 mb-6 max-w-lg mx-auto lg:mx-0">
            {t("home.subtitle")}
          </p>
          <a
            href={localizePath(locale, "/downloads")}
            class="inline-flex gap-1.5 items-center bg-[#557dde] hover:bg-[#558ede] text-white px-3 py-1.5 rounded-xl text-lg sm:text-xl transition-colors duration-200"
          >
            <Icon name="material-symbols:download-rounded" width={36} height={36} />
            {t("home.downloads")}
          </a>
        </div>

        <!-- Right Content - Logo -->
        <div class="flex justify-center lg:justify-end order-1 lg:order-2 lg:flex-1">
          <Logo class="w-54 h-42 sm:w-60 sm:h-48 md:w-72 md:h-54 lg:w-96 lg:h-auto object-contain" />
        </div>
      </div>
    </section>

    <!-- Featured Images Section -->
    <section class="container mx-auto py-6">
      <Carousel />
    </section>

    <!-- Features Section -->
    <section class="container mx-auto">
      <FeatureTabs locale={locale} />
    </section>

    <!-- Ages walkthrough Section -->
    <section class="container mx-auto">
      <AgesWalkthrough locale={locale} />
    </section>

    <!-- Call to action section -->
    <section class="container mx-auto py-6">
      <CallToAction locale={locale} />
    </section>
  </div>
</BaseLayout>
