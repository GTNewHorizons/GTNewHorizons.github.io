---
import { locales } from "../i18n";

const supported: Record<string, string> = {};
for (const l of locales) {
  supported[l] = `/${l}/`;
  supported[l.slice(0, 2)] ??= `/${l}/`;
}
const defaultLocale = locales[0];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>GregTech: New Horizons</title>
    <style>
      body { margin: 0; background: #16191c; }
      .loader { display: flex; align-items: center; justify-content: center; height: 100vh; color: #7c9de4; font-family: system-ui, sans-serif; font-size: 1.125rem; }
    </style>
  </head>
  <body>
    <div class="loader">GregTech: New Horizons</div>
    <script is:inline define:vars={{ supported, defaultLocale }}>
      (function() {
        var lang = navigator.language || navigator.languages?.[0] || defaultLocale;
        var target = "/" + defaultLocale + "/";
        for (var code in supported) {
          if (lang === code || lang.indexOf(code + "-") === 0 || lang.indexOf(code + "_") === 0) {
            target = supported[code];
            break;
          }
        }
        window.location.replace(target);
      })();
    </script>
  </body>
</html>
