---
import { locales, getLocaleLabel, localizePath } from "../../i18n";
import type { Locale } from "../../i18n";

const { locale = locales[0] } = Astro.props as { locale: Locale };
---

<div class="relative inline-block">
  <select
    id="lang-picker"
    class="appearance-none bg-transparent text-gray-300 hover:text-white cursor-pointer text-base pr-4 focus:outline-none"
    aria-label="Switch language"
  >
    {locales.map((l) => (
      <option value={l} selected={l === locale}>{getLocaleLabel(l)}</option>
    ))}
  </select>
  <span class="pointer-events-none absolute right-0 top-1/2 -translate-y-1/2 text-gray-400">
    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
      <path d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" />
    </svg>
  </span>
</div>

<script>
  document.getElementById("lang-picker")?.addEventListener("change", function() {
    const targetLocale = this.value;
    const newPath = window.location.pathname.replace(/^\/[^\/]+/, "/" + targetLocale);
    window.location.href = newPath + window.location.search + window.location.hash;
  });
</script>
