---
import { locales, getLocaleLabel } from "../../i18n";
import type { Locale } from "../../i18n";

const { locale = locales[0] } = Astro.props as { locale: Locale };
---

<div class="relative inline-block">
  <button type="button" class="lang-btn flex items-center gap-1.5 text-gray-300 hover:text-white transition-colors duration-200 text-base cursor-pointer bg-transparent border-0 p-0 font-space-grotesk">
    {getLocaleLabel(locale)}
    <svg class="w-3 h-3 mt-0.5 text-gray-400 transition-transform duration-200 lang-chevron" fill="currentColor" viewBox="0 0 20 20">
      <path d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" />
    </svg>
  </button>

  <div class="lang-menu absolute right-0 mt-2 min-w-[180px] bg-[#1a1f26] border border-gray-700 rounded-xl shadow-lg py-1 hidden z-[1002]">
    {locales.map((l) => (
      <button
        type="button"
        class="lang-option w-full text-left px-4 py-2 text-sm transition-colors duration-150 font-space-grotesk cursor-pointer border-0"
        class:list={[l === locale ? "text-white bg-[#2a3342]" : "text-gray-400 hover:text-white hover:bg-[#2a3342]"]}
        data-locale={l}
      >
        {getLocaleLabel(l)}
      </button>
    ))}
  </div>
</div>

<script>
  (function() {
    const btns = document.querySelectorAll(".lang-btn");
    btns.forEach(function(btn) {
      const root = btn.parentElement;
      if (!root) return;
      const menu = root.querySelector(".lang-menu");
      const chevron = btn.querySelector(".lang-chevron");
      if (!menu) return;

      function close() {
        menu.classList.add("hidden");
        if (chevron) chevron.style.transform = "";
        menu.style.left = "";
        menu.style.right = "";
      }

      btn.addEventListener("click", function(e) {
        e.stopPropagation();
        const isOpen = !menu.classList.contains("hidden");
        close();
        if (!isOpen) {
          // Position before showing to prevent flash
          menu.style.left = "";
          menu.style.right = "";
          btn.parentElement?.classList.add("overflow-visible", "md:overflow-visible");

          var gap = 8;
          var btnRect = btn.getBoundingClientRect();
          var menuWidth = 200;
          var spaceRight = window.innerWidth - btnRect.right;
          var spaceLeft = btnRect.left;

          if (spaceLeft < menuWidth && spaceRight >= menuWidth) {
            menu.style.right = "auto";
            menu.style.left = "0";
          } else if (spaceRight < menuWidth && spaceLeft >= menuWidth) {
            menu.style.right = "0";
            menu.style.left = "auto";
          } else if (spaceLeft < menuWidth && spaceRight < menuWidth) {
            menu.style.right = String(Math.max(gap, spaceRight - gap)) + "px";
            menu.style.left = "auto";
          } else {
            menu.style.right = "0";
            menu.style.left = "auto";
          }

          menu.classList.remove("hidden");
          if (chevron) chevron.style.transform = "rotate(180deg)";
        }
      });

      menu.querySelectorAll(".lang-option").forEach(function(opt) {
        opt.addEventListener("click", function() {
          const targetLocale = this.dataset.locale;
          const newPath = window.location.pathname.replace(/^\/[^\/]+/, "/" + targetLocale);
          window.location.href = newPath + window.location.search + window.location.hash;
        });
      });
    });

    document.addEventListener("click", function(e) {
      document.querySelectorAll(".lang-menu").forEach(function(menu) {
        const root = menu.parentElement;
        if (!root || (!menu.contains(e.target as Node) && !root.querySelector(".lang-btn")?.contains(e.target as Node))) {
          menu.classList.add("hidden");
          menu.style.left = "";
          menu.style.right = "";
          const chev = root?.querySelector(".lang-chevron");
          if (chev) (chev as HTMLElement).style.transform = "";
        }
      });
    });
  })();
</script>
