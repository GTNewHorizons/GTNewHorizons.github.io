---
import Link from "../shared/Link.astro";
import LogoNhWhite from "../../assets/logo-nh-white.svg";
import config from "../../config";
import { useTranslations, localizePath } from "../../i18n";
import type { Locale } from "../../i18n";

const { locale = "en" } = Astro.props as { locale: Locale };
const t = useTranslations(locale);

// Footer sections data
const footerSections = [
  {
    title: t("common.footer.downloads"),
    links: [
      { name: t("common.footer.downloadsPage"), href: localizePath(locale, "/downloads") },
      { name: t("common.footer.technic"), href: config.technicUrl, external: true },
      { name: t("common.footer.curseforge"), href: config.curseforgeUrl, external: true },
      { name: t("common.footer.versionHistory"), href: localizePath(locale, "/version-history") },
    ],
  },
  {
    title: t("common.footer.resources"),
    links: [
      { name: t("common.footer.wiki"), href: config.wikiUrl, external: true },
      { name: t("common.footer.faq"), href: localizePath(locale, "/faq") },
    ],
  },
  {
    title: t("common.footer.community"),
    links: [
      { name: t("common.footer.discordServer"), href: config.discordUrl, external: true },
      { name: t("common.footer.github"), href: config.githubUrl, external: true },
      { name: t("common.footer.bugReports"), href: config.bugReportsUrl, external: true },
    ],
  },
];
---

<footer class="bg-custom-dark text-white border-t border-gray-700">
  <div class="container mx-auto px-3 py-7">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-6 gap-6">
      <!-- Logo and Description -->
      <div class="lg:col-span-3">
        <div class="flex items-center space-x-1.5 mb-1.5 sm:mb-3">
          <LogoNhWhite class="h-12 w-12 flex-shrink-0" />
          <span class="text-lg font-audiowide">{t("common.brand.short")}</span>
        </div>
        <p class="text-gray-500 text-sm sm:text-base">{t("common.footer.poweredBy", { generator: Astro.generator })}</p>
        <p class="text-gray-500 text-sm sm:text-base">
          {t("common.footer.openSource")} <Link href={config.repoUrl} blank>{t("common.footer.forkMe")}</Link>
        </p>
      </div>

      <!-- Footer Links -->
      {
        footerSections.map((section) => (
          <div class="lg:col-span-1">
            <h3 class="text-lg sm:text-xl font-semibold mb-1.5 sm:mb-3">{section.title}</h3>
            <ul class="space-y-1.5">
              {section.links.map((link) => (
                <li>
                  <Link
                    href={link.href}
                    class="text-gray-400 hover:text-white transition-colors duration-200 text-base sm:text-lg"
                    blank={link.external}
                  >
                    {link.name}
                  </Link>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</footer>
