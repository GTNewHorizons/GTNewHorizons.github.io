---
import ChallengeCard from "./ChallengeCard.astro";
import AgePanel from "./AgePanel.astro";
import AgeBubble from "./AgeBubble.astro";
import { useTranslations } from "../../i18n";
import type { Locale } from "../../i18n";

import stoneAgeImage from "../../assets/home/ages/stone.png";
import steamAgeImage from "../../assets/home/ages/steam.png";
import lvAgeImage from "../../assets/home/ages/lv.png";
import mvAgeImage from "../../assets/home/ages/mv.png";
import hvAgeImage from "../../assets/home/ages/hv.png";
import evAgeImage from "../../assets/home/ages/ev.png";
import ivAgeImage from "../../assets/home/ages/iv.png";
import luvAgeImage from "../../assets/home/ages/luv.png";
import beyondAgeImage from "../../assets/home/ages/beyond.png";

import screenshotStoneAge from "../../assets/home/ages/screens/stone_age.png";
import screenshotSteamAge from "../../assets/home/ages/screens/steam_age.png";
import screenshotLVAge from "../../assets/home/ages/screens/lv.png";
import screenshotMVAge from "../../assets/home/ages/screens/mv.png";
import screenshotHVAge from "../../assets/home/ages/screens/hv.png";
import screenshotEVAge from "../../assets/home/ages/screens/ev.png";
import screenshotIVAge from "../../assets/home/ages/screens/iv.png";
import screenshotLUVAge from "../../assets/home/ages/screens/luv.png";
import screenshotBeyond from "../../assets/home/ages/screens/beyond.png";

import challengeStoneExploration from "../../assets/home/ages/challenge_icons/stone_age/exploration.png";
import challengeStoneSurvival from "../../assets/home/ages/challenge_icons/stone_age/survival.png";
import challengeSteamProduction from "../../assets/home/ages/challenge_icons/steam_age/steam_production.png";
import challengeSteamTinkerWeaponry from "../../assets/home/ages/challenge_icons/steam_age/tinker_weapon.png";
import challengeLVEnergyProduction from "../../assets/home/ages/challenge_icons/lv/steam_turbine.png";
import ChallengeLVEBF from "../../assets/home/ages/challenge_icons/lv/ebf.png";
import ChallengeMVSilicon from "../../assets/home/ages/challenge_icons/mv/silicon.png";
import ChallengeMVKanthal from "../../assets/home/ages/challenge_icons/mv/kanthal.png";
import challengeHVCleanroom from "../../assets/home/ages/challenge_icons/hv/cleanroom.png";
import challengeHVRocket from "../../assets/home/ages/challenge_icons/hv/rocket.png";
import challengeEVAE2 from "../../assets/home/ages/challenge_icons/ev/ae2.gif";
import challengeEVRadon from "../../assets/home/ages/challenge_icons/ev/radon.png";
import challengeIVPlatline from "../../assets/home/ages/challenge_icons/iv/platinum.png";
import challengeIVAssline from "../../assets/home/ages/challenge_icons/iv/assline.png";
import challengeLUVFusion from "../../assets/home/ages/challenge_icons/luv/fusion.png";
import challengeLUVNaquadah from "../../assets/home/ages/challenge_icons/luv/naquadah.png";
import challengeBeyondMM from "../../assets/home/ages/challenge_icons/beyond/mm.png";
import challengeBeyondStargate from "../../assets/home/ages/challenge_icons/beyond/stargate.png";

const { locale = "en" } = Astro.props as { locale: Locale };
const t = useTranslations(locale);
const q = t("home.ages.stone.quests");
const ch = t("home.agePanels.challenges");
---

<section class="container mx-auto px-4 sm:py-10">
  <div class="text-center mb-6">
    <h2 class="text-xl sm:text-2xl lg:text-4xl font-bold mb-1.5">{t("home.agesWalkthrough")}</h2>
    <p class="text-gray-300 text-lg lg:text-xl">
      {t("home.agesDescription")}
    </p>
  </div>

  <div class="mt-7 overflow-x-auto snap-x snap-mandatory pb-3" id="ages-track" data-active="stone">
    <ul class="flex flex-nowrap items-start w-max md:w-full px-1.5">
      <AgeBubble age="stone" label={t("home.ages.stone.label")} image={stoneAgeImage} />
      <AgeBubble age="steam" label={t("home.ages.steam.label")} image={steamAgeImage} />
      <AgeBubble age="lv" label={t("home.ages.lv.label")} image={lvAgeImage} />
      <AgeBubble age="mv" label={t("home.ages.mv.label")} image={mvAgeImage} />
      <AgeBubble age="hv" label={t("home.ages.hv.label")} image={hvAgeImage} />
      <AgeBubble age="ev" label={t("home.ages.ev.label")} image={evAgeImage} />
      <AgeBubble age="iv" label={t("home.ages.iv.label")} image={ivAgeImage} />
      <AgeBubble age="luv" label={t("home.ages.luv.label")} image={luvAgeImage} />
      <AgeBubble age="beyond" label={t("home.ages.beyond.label")} image={beyondAgeImage} isLast={true} />
    </ul>
  </div>

  <AgePanel id="panel-stone" title={t("home.ages.stone.label")} quests={137} questsLabel={q} challengesLabel={ch} image={screenshotStoneAge} caption="Mountain" author="iLex">
    <div slot="lead">
      <p class="text-gray-300 mb-3 text-base sm:text-lg lg:text-xl">
        {t("home.agePanels.stone.lead")}
      </p>
    </div>
    <div slot="more">
      <p class="text-gray-300 mb-6 text-base sm:text-lg lg:text-xl">
        {t("home.agePanels.stone.more")}
      </p>
    </div>
    <ChallengeCard slot="challenges" imageIcon={challengeStoneExploration} title={t("home.agePanels.stone.exploration.title")}
      >{t("home.agePanels.stone.exploration.desc")}</ChallengeCard
    >
    <ChallengeCard slot="challenges" imageIcon={challengeStoneSurvival} title={t("home.agePanels.stone.survival.title")}
      >{t("home.agePanels.stone.survival.desc")}</ChallengeCard
    >
  </AgePanel>

  <AgePanel
    id="panel-steam"
    title={t("home.ages.steam.label")}
    quests={114}
    questsLabel={q} challengesLabel={ch}
    image={screenshotSteamAge}
    caption="Steam Engineering"
    author="Li Muli"
  >
    <div slot="lead">
      <p class="text-gray-300 mb-3 text-base sm:text-lg lg:text-xl">{t("home.agePanels.steam.lead")}</p>
    </div>
    <div slot="more">
      <p class="text-gray-300 mb-6 text-base sm:text-lg lg:text-xl">
        {t("home.agePanels.steam.more")}
      </p>
    </div>
    <ChallengeCard slot="challenges" imageIcon={challengeSteamProduction} title={t("home.agePanels.steam.steamProduction.title")}
      >{t("home.agePanels.steam.steamProduction.desc")}</ChallengeCard
    >
    <ChallengeCard slot="challenges" imageIcon={challengeSteamTinkerWeaponry} title={t("home.agePanels.steam.weapons.title")}
      >{t("home.agePanels.steam.weapons.desc")}</ChallengeCard
    >
  </AgePanel>

  <AgePanel
    id="panel-lv"
    title={t("home.ages.lv.label")}
    quests={155}
    questsLabel={q} challengesLabel={ch}
    image={screenshotLVAge}
    caption="Logistics Pipes Storage Center"
    author="GeForceX"
  >
    <div slot="lead">
      <p class="text-gray-300 mb-4 text-base sm:text-lg lg:text-xl">{t("home.agePanels.lv.lead")}</p>
    </div>
    <div slot="more">
      <p class="text-gray-300 mb-8 text-base sm:text-lg lg:text-xl">
        {t("home.agePanels.lv.more")}
      </p>
    </div>
    <ChallengeCard
      slot="challenges"
      imageIcon={challengeLVEnergyProduction}
      title={t("home.agePanels.lv.energy.title")}
      >{t("home.agePanels.lv.energy.desc")}</ChallengeCard
    >
    <ChallengeCard slot="challenges" imageIcon={ChallengeLVEBF} title={t("home.agePanels.lv.ebf.title")}
      >{t("home.agePanels.lv.ebf.desc")}</ChallengeCard
    >
  </AgePanel>

  <AgePanel
    id="panel-mv"
    title={t("home.ages.mv.label")}
    quests={147}
    questsLabel={q} challengesLabel={ch}
    image={screenshotMVAge}
    caption="Mid MV Chaotic Base"
    author="Mayk"
    active
  >
    <div slot="lead">
      <p class="text-gray-300 mb-4 text-base sm:text-lg lg:text-xl">{t("home.agePanels.mv.lead")}</p>
    </div>
    <div slot="more">
      <p class="text-gray-300 mb-8 text-base sm:text-lg lg:text-xl">
        {t("home.agePanels.mv.more")}
      </p>
    </div>
    <ChallengeCard slot="challenges" imageIcon={ChallengeMVSilicon} title={t("home.agePanels.mv.silicon.title")}
      >{t("home.agePanels.mv.silicon.desc")}</ChallengeCard
    >
    <ChallengeCard slot="challenges" imageIcon={ChallengeMVKanthal} title={t("home.agePanels.mv.kanthal.title")}
      >{t("home.agePanels.mv.kanthal.desc")}</ChallengeCard
    >
  </AgePanel>

  <AgePanel
    id="panel-hv"
    title={t("home.ages.hv.label")}
    quests={115}
    questsLabel={q} challengesLabel={ch}
    image={screenshotHVAge}
    caption="Rocket Launch Site"
    author="Ban4iko"
  >
    <div slot="lead">
      <p class="text-gray-300 mb-4 text-base sm:text-lg lg:text-xl">{t("home.agePanels.hv.lead")}</p>
    </div>
    <div slot="more">
      <p class="text-gray-300 mb-8 text-base sm:text-lg lg:text-xl">
        {t("home.agePanels.hv.more")}
      </p>
    </div>
    <ChallengeCard slot="challenges" imageIcon={challengeHVCleanroom} title={t("home.agePanels.hv.cleanroom.title")}
      >{t("home.agePanels.hv.cleanroom.desc")}</ChallengeCard
    >
    <ChallengeCard slot="challenges" imageIcon={challengeHVRocket} title={t("home.agePanels.hv.rocket.title")}
      >{t("home.agePanels.hv.rocket.desc")}</ChallengeCard
    >
  </AgePanel>

  <AgePanel
    id="panel-ev"
    title={t("home.ages.ev.label")}
    quests={94}
    questsLabel={q} challengesLabel={ch}
    image={screenshotEVAge}
    caption="AE2 Basement"
    author="Johny"
  >
    <div slot="lead">
      <p class="text-gray-300 mb-4 text-base sm:text-lg lg:text-xl">{t("home.agePanels.ev.lead")}</p>
    </div>
    <div slot="more">
      <p class="text-gray-300 mb-8 text-base sm:text-lg lg:text-xl">
        {t("home.agePanels.ev.more")}
      </p>
    </div>
    <ChallengeCard slot="challenges" imageIcon={challengeEVAE2} title={t("home.agePanels.ev.ae2.title")}
      >{t("home.agePanels.ev.ae2.desc")}</ChallengeCard
    >
    <ChallengeCard slot="challenges" imageIcon={challengeEVRadon} title={t("home.agePanels.ev.radon.title")}
      >{t("home.agePanels.ev.radon.desc")}</ChallengeCard
    >
  </AgePanel>

  <AgePanel
    id="panel-iv"
    title={t("home.ages.iv.label")}
    quests={132}
    questsLabel={q} challengesLabel={ch}
    image={screenshotIVAge}
    caption="Platinum Group Processing"
    author="ImpossibleVT"
  >
    <div slot="lead">
      <p class="text-gray-300 mb-4 text-base sm:text-lg lg:text-xl">{t("home.agePanels.iv.lead")}</p>
    </div>
    <div slot="more">
      <p class="text-gray-300 mb-8 text-base sm:text-lg lg:text-xl">
        {t("home.agePanels.iv.more")}
      </p>
    </div>
    <ChallengeCard slot="challenges" imageIcon={challengeIVPlatline} title={t("home.agePanels.iv.platinum.title")}
      >{t("home.agePanels.iv.platinum.desc")}</ChallengeCard
    >
    <ChallengeCard slot="challenges" imageIcon={challengeIVAssline} title={t("home.agePanels.iv.assline.title")}
      >{t("home.agePanels.iv.assline.desc")}</ChallengeCard
    >
  </AgePanel>

  <AgePanel
    id="panel-luv"
    title={t("home.ages.luv.label")}
    quests={83}
    questsLabel={q} challengesLabel={ch}
    image={screenshotLUVAge}
    caption="Mid-Late LuV Base"
    author="Rubydragon, gnommis and woofdoggo"
  >
    <div slot="lead">
      <p class="text-gray-300 mb-4 text-base sm:text-lg lg:text-xl">
        {t("home.agePanels.luv.lead")}
      </p>
    </div>
    <div slot="more">
      <p class="text-gray-300 mb-8 text-base sm:text-lg lg:text-xl">
        {t("home.agePanels.luv.more")}
      </p>
    </div>
    <ChallengeCard slot="challenges" imageIcon={challengeLUVNaquadah} title={t("home.agePanels.luv.naquadah.title")}
      >{t("home.agePanels.luv.naquadah.desc")}</ChallengeCard
    >
    <ChallengeCard slot="challenges" imageIcon={challengeLUVFusion} title={t("home.agePanels.luv.fusion.title")}
      >{t("home.agePanels.luv.fusion.desc")}
    </ChallengeCard>
  </AgePanel>

  <AgePanel
    id="panel-beyond"
    title={t("home.ages.beyond.label")}
    quests={291}
    questsLabel={q} challengesLabel={ch}
    image={screenshotBeyond}
    caption="Light of the New Age"
    author="Semetix, Bl1nkle, Tbone, lui993 and P_A_JN"
  >
    <div slot="lead">
      <p class="text-gray-300 mb-4 text-base sm:text-lg lg:text-xl">{t("home.agePanels.beyond.lead")}</p>
    </div>
    <div slot="more">
      <p class="text-gray-300 mb-8 text-base sm:text-lg lg:text-xl">
        {t("home.agePanels.beyond.more")}
      </p>
    </div>
    <ChallengeCard slot="challenges" imageIcon={challengeBeyondMM} title={t("home.agePanels.beyond.infrastructure.title")}
      >{t("home.agePanels.beyond.infrastructure.desc")}</ChallengeCard
    >
    <ChallengeCard
      slot="challenges"
      imageIcon={challengeBeyondStargate}
      title={t("home.agePanels.beyond.stargate.title")}
      caption="Light of the new Age"
      author="Semetix, Bl1nkle, Tbone, lui993 and P_A_JN"
      >{t("home.agePanels.beyond.stargate.desc")}</ChallengeCard
    >
  </AgePanel>
</section>

<script is:inline>
  (function () {
    var STORAGE_KEY = "gtnh:ageTab";
    var DEFAULT_AGE = "stone";

    function loadSaved() {
      try {
        var data = JSON.parse(localStorage.getItem(STORAGE_KEY));
        if (data && data.value && Date.now() < data.expires) return data.value;
      } catch(e) {}
      return null;
    }

    function saveAge(age) {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify({ value: age, expires: Date.now() + 30 * 60 * 1000 }));
      } catch(e) {}
    }

    const track = document.getElementById("ages-track");
    const ageItems = Array.from(document.querySelectorAll(".age-item"));
    const panels = {
      stone: document.getElementById("panel-stone"),
      steam: document.getElementById("panel-steam"),
      lv: document.getElementById("panel-lv"),
      mv: document.getElementById("panel-mv"),
      hv: document.getElementById("panel-hv"),
      ev: document.getElementById("panel-ev"),
      iv: document.getElementById("panel-iv"),
      luv: document.getElementById("panel-luv"),
      beyond: document.getElementById("panel-beyond"),
    };

    function setActive(age) {
      track.dataset.active = age;
      const activeIndex = ageItems.findIndex((item) => item.dataset.age === age);

      // Update age items with classes
      ageItems.forEach((item, index) => {
        item.classList.remove("active", "completed");

        if (index === activeIndex) {
          item.classList.add("active");
        } else if (index < activeIndex) {
          item.classList.add("completed");
        }
      });

      // Show/hide panels
      Object.entries(panels).forEach(([key, panel]) => {
        if (!panel) return;
        if (key === age) {
          panel.classList.remove("hidden");
        } else {
          panel.classList.add("hidden");
        }
      });
    }

    function initialize() {
      // Add click listeners to all age buttons
      ageItems.forEach((item) => {
        const button = item.querySelector(".age-bubble");
        if (button) {
          button.addEventListener("click", function () {
            setActive(this.closest(".age-item").dataset.age);
            saveAge(this.closest(".age-item").dataset.age);
          });
        }
      });

      // Set initial active state (saved or default)
      setActive(loadSaved() || track.dataset.active || DEFAULT_AGE);
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initialize);
    } else {
      initialize();
    }
  })();
</script>
