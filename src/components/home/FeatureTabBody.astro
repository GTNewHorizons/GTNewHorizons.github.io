---
import { Icon } from "astro-icon/components";
import config from "../../config";
import { useTranslations } from "../../i18n";
import type { Locale } from "../../i18n";

interface Props {
  id: string;
  locale: Locale;
}

const { id, locale } = Astro.props;
const t = useTranslations(locale);
---

{
  id === "techAdventure" && (
    <div class="[&:not(:last-child)]:mb-4" style="white-space: pre-line">{t("home.featureBodies.techAdventure")}</div>
  )
}

{
  id === "journey" && (
    <div style="white-space: pre-line">{t("home.featureBodies.journey")}</div>
  )
}

{
  id === "playstyles" && (
    <div style="white-space: pre-line">{t("home.featureBodies.playstyles")}</div>
  )
}

{
  id === "technical" && (
    <>
      <div style="white-space: pre-line">{t("home.featureBodies.technical")}</div>
      <div class="mt-6">
        <a
          href={config.githubUrl}
          target="_blank"
          class="inline-flex items-center gap-2 bg-white text-black px-4 py-2 rounded-xl text-lg font-semibold hover:bg-gray-300 transition-colors"
        >
          <Icon name="mdi:github" class="w-7 h-7" />
          {t("home.featureBodies.ourGithub")}
        </a>
      </div>
    </>
  )
}

{
  id === "community" && (
    <div style="white-space: pre-line">{t("home.featureBodies.community")}</div>
  )
}
