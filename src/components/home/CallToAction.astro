---
import { Icon } from "astro-icon/components";
import config from "../../config";
import { useTranslations, localizePath } from "../../i18n";
import type { Locale } from "../../i18n";

const { locale = "en" } = Astro.props as { locale: Locale };
const t = useTranslations(locale);
---

<div class="bg-[#2e3338] border-gray-500 border-1 rounded-2xl p-4 sm:p-7 mx-3">
  <div class="text-center">
    <h2 class="text-lg sm:text-2xl lg:text-4xl font-bold text-white mb-2 sm:mb-4">{t("home.readyToBegin")}</h2>
    <p class="text-gray-300 text-base sm:text-xl lg:text-2xl mb-3 sm:mb-6 max-w-3xl mx-auto">
      {t("home.joinPlayers")}
    </p>

    <div class="flex flex-col sm:flex-row gap-2 sm:gap-3 justify-center items-center">
      <!-- Downloads Button -->
      <a
        href={localizePath(locale, "/downloads")}
        class="inline-flex sm:gap-1.5 items-center justify-center w-48 whitespace-nowrap bg-[#557dde] hover:bg-[#558ede] text-white px-2 sm:px-3 py-1.5 sm:py-2 rounded-lg text-base sm:text-lg md:text-xl transition-colors duration-200"
      >
        <Icon name="material-symbols:download-rounded" class="w-6 sm:w-7 h-6 sm:h-7" />
        {t("home.downloads")}
      </a>

      <!-- GitHub Button -->
      <a
        href={config.githubUrl}
        target="_blank"
        class="inline-flex items-center justify-center gap-1 sm:gap-2 w-48 whitespace-nowrap bg-white text-black px-2 sm:px-4 py-1.5 sm:py-2 rounded-lg text-base sm:text-lg md:text-xl font-semibold hover:bg-gray-300 transition-colors"
      >
        <Icon name="mdi:github" class="w-6 sm:w-7 h-6 sm:h-7" />
        Github
      </a>

      <!-- Discord Button -->
      <a
        href={config.discordUrl}
        target="_blank"
        class="inline-flex gap-1 sm:gap-1.5 items-center justify-center w-48 whitespace-nowrap bg-[#5864f2] hover:bg-[#587cf2] text-white px-2 sm:px-4 py-1.5 sm:py-2 rounded-lg text-base sm:text-lg md:text-xl transition-colors duration-200"
      >
        <Icon name="ic:baseline-discord" class="w-6 sm:w-7 h-6 sm:h-7" />
        {t("home.joinDiscord")}
      </a>
    </div>
  </div>
</div>
